# ==========================================
# EMOTETECHNOLOGY - BACKEND CONFIGURATION
# ==========================================
# Copy this file to .env and update the values

# MongoDB Connection
# Production: Use MongoDB Atlas connection string
# Development: Use local MongoDB or Atlas
MONGODB_URL=your_mongodb_connection_string_here

# Server Configuration
PORT=5000
NODE_ENV=development

# CORS Configuration
# Frontend URL for CORS (comma-separated for multiple origins)
FRONTEND_URL=http://localhost:5173

# JWT Configuration
# Secret key for signing JWT tokens (CHANGE IN PRODUCTION!)
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-2024
JWT_EXPIRES_IN=7d
# SMTP Configuration (for email notifications and password reset)
# Gmail SMTP:
# - Enable 2FA on your Google account
# - Generate an App Password: https://support.google.com/accounts/answer/185833
# - Use the App Password as SMTP_PASSWORD
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
# BunnyCDN Configuration
BUNNY_REGION=
BUNNY_STORAGE_ZONE=
BUNNY_ACCESS_KEY=
BUNNY_PULL_ZONE_URL=

# Razorpay Configuration
RAZORPAY_API_KEY=your_razorpay_key_id
RAZORPAY_API_SECRET=your_razorpay_key_secret

# Firebase Admin SDK Configuration
# Store each credential separately — DO NOT use a JSON blob.
# Get these values from your Firebase project > Service Accounts > Generate New Private Key.
# FIREBASE_PRIVATE_KEY: Copy the private_key value from the JSON file.
#   - Wrap it in double quotes in .env
#   - Keep \n as literal two-character sequences (NOT real newlines)
#   - The server will call .replace(/\\n/g, '\n') to convert them at runtime.
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
